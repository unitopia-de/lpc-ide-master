{
  "dialect": "ldmud",
  "version": "3.6.7",
  "mudlib": {
    "name": "UNIlib",
    "baseDir": "/sys/unitopia",
    "simulEfunFile": "/sys/simul_efun.c",
    "includeDirs": [
      "/sys/include",
      "/std/include",
      "/players/magier/include"
    ],
    "efunDefinitions": "lpc-efuns.json"
  },
  "ftp": {
    "host": "mud.unitopia.de",
    "port": 21,
    "user": "magier",
    "remoteRoot": "/players/magier",
    "protocol": "ftp"
  },
  "mud": {
    "host": "mud.unitopia.de",
    "port": 4711,
    "user": "magier",
    "protocol": "telnet",
    "loginPrompt": "(Wie heisst du|Bitte gib Deinen Namen ein|Name)",
    "passwordPrompt": "Passwort",
    "commandPrompt": "^(>|magier@unitopia>)\\s*$",
    "completionMarker": "###LPC_IDE_DONE###"
  },
  "homemud": {
    "path": "./mud",
    "libPath": "/lib",
    "mud": {
      "host": "localhost",
      "port": 4711,
      "protocol": "telnet",
      "commandPrompt": "^>\\s*$"
    }
  }
}
