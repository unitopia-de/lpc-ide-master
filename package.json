{
  "name": "lpc-ide-master",
  "displayName": "LPC-IDE-Master (UNItopia Edition)",
  "description": "LPC-Entwicklungsumgebung mit Dialekt-Management, Remote-FTP-Sync und LSP-Unterstützung für UNItopia und weitere Mudlibs.",
  "version": "0.1.0",
  "publisher": "wd-ideenmanufaktur",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "lpc",
    "ldmud",
    "unitopia",
    "mud",
    "ftp"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onFileSystem:lpc-ftp",
    "workspaceContains:lpc-config.json"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lpc",
        "aliases": [
          "LPC",
          "lpc"
        ],
        "extensions": [
          ".c",
          ".h",
          ".lpc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lpc",
        "scopeName": "source.lpc",
        "path": "./syntaxes/lpc.tmLanguage.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "lpc-config.json",
        "url": "./schemas/lpc-config.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lpcRemote",
          "title": "Remote MUD",
          "icon": "$(remote-explorer)"
        }
      ]
    },
    "views": {
      "lpcRemote": [
        {
          "id": "lpcRemoteExplorer",
          "name": "Remote Explorer",
          "icon": "$(remote-explorer)",
          "contextualTitle": "LPC Remote MUD"
        }
      ]
    },
    "commands": [
      { "command": "lpc.connect",            "title": "LPC: Mit MUD verbinden",          "icon": "$(plug)" },
      { "command": "lpc.disconnect",         "title": "LPC: Verbindung trennen",         "icon": "$(debug-disconnect)" },
      { "command": "lpc.refreshRemote",      "title": "LPC: Remote-Baum aktualisieren",  "icon": "$(refresh)" },
      { "command": "lpc.switchDialect",      "title": "LPC: Dialekt wechseln" },
      { "command": "lpc.reloadConfig",       "title": "LPC: lpc-config.json neu laden" },
      { "command": "lpc.changePassword",     "title": "LPC: FTP-Passwort ändern" },
      { "command": "lpc.changeMudPassword",  "title": "LPC: MUD-Passwort ändern" },
      { "command": "lpc.openMudConsole",     "title": "LPC: MUD-Konsole anzeigen",       "icon": "$(terminal)" },
      { "command": "lpc.disconnectMud",      "title": "LPC: MUD-Konsole trennen" },
      { "command": "lpc.updateObject",       "title": "Update Object (update)",          "icon": "$(refresh)" },
      { "command": "lpc.destructObject",     "title": "Destruct Object (destruct)",      "icon": "$(trash)" },
      { "command": "lpc.newFile",            "title": "Neue Datei",                      "icon": "$(new-file)" },
      { "command": "lpc.newFolder",          "title": "Neuer Ordner",                    "icon": "$(new-folder)" },
      { "command": "lpc.renameRemote",       "title": "Umbenennen" },
      { "command": "lpc.deleteRemote",       "title": "Löschen" },
      { "command": "lpc.copyRemotePath",     "title": "Pfad kopieren" }
    ],
    "menus": {
      "view/title": [
        { "command": "lpc.connect",        "when": "view == lpcRemoteExplorer", "group": "navigation@1" },
        { "command": "lpc.refreshRemote",  "when": "view == lpcRemoteExplorer", "group": "navigation@2" },
        { "command": "lpc.openMudConsole", "when": "view == lpcRemoteExplorer", "group": "navigation@3" },
        { "command": "lpc.disconnect",     "when": "view == lpcRemoteExplorer", "group": "1_connection" }
      ],
      "view/item/context": [
        { "command": "lpc.newFile",        "when": "view == lpcRemoteExplorer && viewItem == lpcDir",  "group": "inline@1" },
        { "command": "lpc.newFolder",      "when": "view == lpcRemoteExplorer && viewItem == lpcDir",  "group": "inline@2" },
        { "command": "lpc.refreshRemote",  "when": "view == lpcRemoteExplorer && viewItem == lpcDir",  "group": "1_navigation" },
        { "command": "lpc.updateObject",   "when": "view == lpcRemoteExplorer && viewItem == lpcFile", "group": "2_mud@1" },
        { "command": "lpc.destructObject", "when": "view == lpcRemoteExplorer && viewItem == lpcFile", "group": "2_mud@2" },
        { "command": "lpc.renameRemote",   "when": "view == lpcRemoteExplorer",                       "group": "3_modify@1" },
        { "command": "lpc.deleteRemote",   "when": "view == lpcRemoteExplorer",                       "group": "3_modify@2" },
        { "command": "lpc.copyRemotePath", "when": "view == lpcRemoteExplorer",                       "group": "9_copy" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "lpcRemoteExplorer",
        "contents": "Keine FTP-Konfiguration gefunden.\n\nLege eine [lpc-config.json](command:lpc.reloadConfig) im Workspace-Root an und ergänze einen `ftp`-Block.\n\n[Konfiguration neu laden](command:lpc.reloadConfig)",
        "when": "!lpc.hasFtpConfig"
      },
      {
        "view": "lpcRemoteExplorer",
        "contents": "Mit dem MUD verbinden, um den Remote-Baum zu laden.\n\n[Verbinden](command:lpc.connect)",
        "when": "lpc.hasFtpConfig && !lpc.ftpConnected"
      }
    ],
    "configuration": {
      "title": "LPC-IDE-Master",
      "properties": {
        "lpc.configFile": {
          "type": "string",
          "default": "lpc-config.json",
          "description": "Pfad zur LPC-Konfigurationsdatei (relativ zum Workspace-Root)."
        },
        "lpc.dialect.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Beim Öffnen eines Workspaces automatisch den Dialekt erkennen."
        },
        "lpc.ftp.uploadOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Dateien beim Speichern automatisch via FTP zum MUD übertragen."
        },
        "lpc.ftp.protocol": {
          "type": "string",
          "enum": [
            "ftp",
            "sftp"
          ],
          "default": "ftp",
          "description": "Übertragungsprotokoll für die Remote-Synchronisation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "ssh2-sftp-client": "^12.1.1",
    "vscode-languageclient": "^9.0.1"
  }
}
