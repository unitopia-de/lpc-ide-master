{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LPC-IDE-Master Configuration",
  "description": "Konfiguration für Dialekt und Mudlib-Spezifikationen.",
  "type": "object",
  "required": ["dialect", "mudlib"],
  "properties": {
    "dialect": {
      "type": "string",
      "enum": ["ldmud", "fluffos", "mudos"],
      "description": "Der LPC-Driver-Dialekt."
    },
    "version": {
      "type": "string",
      "description": "Driver-Version, z.B. 3.5.0 oder 3.6.x."
    },
    "mudlib": {
      "type": "object",
      "required": ["name", "baseDir"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name der Mudlib (z.B. UNIlib, MGlib)."
        },
        "baseDir": {
          "type": "string",
          "description": "Wurzelverzeichnis der Mudlib im virtuellen MUD-Dateisystem."
        },
        "simulEfunFile": {
          "type": "string",
          "description": "Pfad zur simul_efun.c relativ zum baseDir oder absolut."
        },
        "includeDirs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Verzeichnisse, die für inherit/include aufgelöst werden."
        },
        "efunDefinitions": {
          "type": "string",
          "description": "Profil-Datei mit vorkompilierten Efun-Definitionen."
        }
      }
    },
    "ftp": {
      "type": "object",
      "description": "Optionale FTP-Verbindungsdaten. Passwörter werden NICHT hier gespeichert.",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "default": 21 },
        "user": { "type": "string" },
        "remoteRoot": { "type": "string" },
        "protocol": { "type": "string", "enum": ["ftp", "sftp"], "default": "ftp" }
      }
    },
    "mud": {
      "type": "object",
      "description": "Telnet-/Telnets-Verbindung zum MUD für Magier-Befehle (update, destruct, ...). Passwörter werden NICHT hier gespeichert.",
      "required": ["host", "user"],
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "description": "Default 4711 (telnet) bzw. 992 (telnets)." },
        "user": { "type": "string", "description": "Magier-Login." },
        "protocol": { "type": "string", "enum": ["telnet", "telnets"], "default": "telnet" },
        "loginPrompt": { "type": "string", "description": "Regex; Default: \"(Name|Wie heisst du)\"." },
        "passwordPrompt": { "type": "string", "description": "Regex; Default: \"Passwort\"." },
        "commandPrompt": { "type": "string", "description": "Regex für den Befehlsprompt; Default: \"^>\\s*$\"." },
        "completionMarker": { "type": "string", "description": "Optionaler Endmarker pro Befehl. Wird nicht in den Output geschrieben." }
      }
    }
  }
}
