{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LPC-IDE-Master Configuration",
  "description": "Konfiguration für Dialekt und Mudlib-Spezifikationen.",
  "type": "object",
  "required": ["dialect", "mudlib"],
  "definitions": {
    "mudConsole": {
      "type": "object",
      "required": ["host"],
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "description": "Default 4711 (telnet) bzw. 992 (telnets)." },
        "user": { "type": "string", "description": "Optional. Fehlt user, wird die Login-Sequenz übersprungen." },
        "protocol": { "type": "string", "enum": ["telnet", "telnets"], "default": "telnet" },
        "loginPrompt": { "type": "string", "description": "Regex; Default: \"(Name|Wie heisst du)\"." },
        "passwordPrompt": { "type": "string", "description": "Regex; Default: \"Passwort\"." },
        "commandPrompt": { "type": "string", "description": "Regex für den Befehlsprompt; Default: \"^>\\s*$\"." },
        "completionMarker": { "type": "string", "description": "Optionaler Endmarker pro Befehl." }
      }
    }
  },
  "properties": {
    "dialect": {
      "type": "string",
      "enum": ["ldmud", "fluffos", "mudos"],
      "description": "Der LPC-Driver-Dialekt."
    },
    "version": {
      "type": "string",
      "description": "Driver-Version, z.B. 3.5.0 oder 3.6.x."
    },
    "mudlib": {
      "type": "object",
      "required": ["name", "baseDir"],
      "properties": {
        "name": { "type": "string" },
        "baseDir": { "type": "string" },
        "simulEfunFile": { "type": "string" },
        "includeDirs": { "type": "array", "items": { "type": "string" } },
        "efunDefinitions": { "type": "string" }
      }
    },
    "ftp": {
      "type": "object",
      "description": "Optionale FTP-Verbindungsdaten. Passwörter werden NICHT hier gespeichert.",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "default": 21 },
        "user": { "type": "string" },
        "remoteRoot": { "type": "string" },
        "protocol": { "type": "string", "enum": ["ftp", "sftp"], "default": "ftp" }
      }
    },
    "mud": {
      "$ref": "#/definitions/mudConsole",
      "description": "Telnet-/Telnets-Verbindung zum REMOTE MUD für Magier-Befehle (update, destruct, ...)."
    },
    "homemud": {
      "type": "object",
      "description": "Optional: lokales Entwicklungs-MUD im Workspace. Erlaubt Sync zwischen remote und lokalem MUD.",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Workspace-relativer Pfad zum lokalen MUD-Verzeichnis."
        },
        "libPath": {
          "type": "string",
          "default": "/lib",
          "description": "Pfad zur Mudlib innerhalb von path."
        },
        "mud": {
          "$ref": "#/definitions/mudConsole",
          "description": "Optional: Telnet-Konsole zum lokalen MUD."
        }
      }
    }
  }
}
